# Shared runner settings
#
# Set ROWS_PER_AGE_GROUP to a positive integer to limit how many rows are loaded per age group.
# Set it to NONE to load the full dataset for every age group.
ROWS_PER_AGE_GROUP=NONE
#
# AutoML only: training time limit in seconds.
# If unset, the default is 14400.
TIME_LIMIT=14400
