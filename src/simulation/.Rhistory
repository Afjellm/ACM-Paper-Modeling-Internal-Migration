library(dplyr)
library(stringr)
library(readr)
library(purrr)
library(tidyr)
library(ggplot2)
library(glue)
library(sf)
library(jsonlite)
library(tibble)
library(scales)
root_dirs <- c(
"../output/ensemble_trees_output",
"../output/autogluon_output"
)
top_folders <- unlist(lapply(root_dirs, list.dirs, recursive = FALSE, full.names = TRUE))
# Function to process each top-level folder
load_data_for_folder <- function(folder_path) {
top_folder_name <- basename(folder_path)
# Walk through all evaluation CSVs under this folder
csv_files <- list.files(folder_path, pattern = "^results.*\\.csv$", recursive = TRUE, full.names = TRUE)
# Load and process each CSV
importances_files <- list.files(folder_path, pattern = "^features_importances.*\\.csv$", recursive = TRUE, full.names = TRUE)
print(importances_files)
df <- map_dfr(csv_files, function(csv_path) {
parts <- str_split(csv_path, "[\\/]")[[1]]
rel_parts <- parts[(which(parts == basename(folder_path)) + 1):length(parts)]
if(length(rel_parts) < 4) {
return()
}
fit_year <- rel_parts[1]
predict_year <- rel_parts[2]
age_group <- rel_parts[3]
read.csv(csv_path, skip = 0) %>%
mutate(
fit_year = fit_year,
predict_year = as.integer(predict_year),
age_group = age_group
)
})
importance_df <- map_dfr(importances_files, function(csv_path) {
parts <- str_split(csv_path, .Platform$file.sep)[[1]]
rel_parts <- parts[(which(parts == basename(folder_path)) + 1):length(parts)]
fit_year <- rel_parts[1]
df <- read.csv(csv_path, skip = 0) %>%
mutate(fit_year = fit_year)
})
assign(paste(top_folder_name, "_importances", sep=""), importance_df, envir=.GlobalEnv)
assign(top_folder_name, df, envir = .GlobalEnv)
}
# Process all top-level folders and assign each result to a dataframe named after the folder
walk(top_folders, load_data_for_folder)
# fix negative values:
standard <- standard %>%
mutate(predicted_in = pmax(predicted_in, 0))
with_constraints_no_cat <- with_constraints_no_cat %>%
mutate(predicted_in = pmax(predicted_in, 0))
with_constraints <- with_constraints %>%
mutate(predicted_in = pmax(predicted_in, 0))
`2YearFit` <- `2YearFit` %>%
mutate(predicted_in = pmax(predicted_in, 0))
`2YearFitFullFeatures` <- `2YearFitFullFeatures` %>%
mutate(predicted_in = pmax(predicted_in, 0))
catboost2YearFit <- catboost2YearFit %>%
mutate(predicted_in = pmax(predicted_in, 0))
library(dplyr)
library(stringr)
library(readr)
library(purrr)
library(tidyr)
library(ggplot2)
library(glue)
library(sf)
library(jsonlite)
library(tibble)
library(scales)
root_dirs <- c(
"../output/catboost_output",
"../output/ensemble_trees_output",
"../output/autogluon_output"
)
top_folders <- unlist(lapply(root_dirs, list.dirs, recursive = FALSE, full.names = TRUE))
# Function to process each top-level folder
load_data_for_folder <- function(folder_path) {
top_folder_name <- basename(folder_path)
# Walk through all evaluation CSVs under this folder
csv_files <- list.files(folder_path, pattern = "^results.*\\.csv$", recursive = TRUE, full.names = TRUE)
# Load and process each CSV
importances_files <- list.files(folder_path, pattern = "^features_importances.*\\.csv$", recursive = TRUE, full.names = TRUE)
print(importances_files)
df <- map_dfr(csv_files, function(csv_path) {
parts <- str_split(csv_path, "[\\/]")[[1]]
rel_parts <- parts[(which(parts == basename(folder_path)) + 1):length(parts)]
if(length(rel_parts) < 4) {
return()
}
fit_year <- rel_parts[1]
predict_year <- rel_parts[2]
age_group <- rel_parts[3]
read.csv(csv_path, skip = 0) %>%
mutate(
fit_year = fit_year,
predict_year = as.integer(predict_year),
age_group = age_group
)
})
importance_df <- map_dfr(importances_files, function(csv_path) {
parts <- str_split(csv_path, .Platform$file.sep)[[1]]
rel_parts <- parts[(which(parts == basename(folder_path)) + 1):length(parts)]
fit_year <- rel_parts[1]
df <- read.csv(csv_path, skip = 0) %>%
mutate(fit_year = fit_year)
})
assign(paste(top_folder_name, "_importances", sep=""), importance_df, envir=.GlobalEnv)
assign(top_folder_name, df, envir = .GlobalEnv)
}
# Process all top-level folders and assign each result to a dataframe named after the folder
walk(top_folders, load_data_for_folder)
# fix negative values:
standard <- standard %>%
mutate(predicted_in = pmax(predicted_in, 0))
with_constraints_no_cat <- with_constraints_no_cat %>%
mutate(predicted_in = pmax(predicted_in, 0))
with_constraints <- with_constraints %>%
mutate(predicted_in = pmax(predicted_in, 0))
`2YearFit` <- `2YearFit` %>%
mutate(predicted_in = pmax(predicted_in, 0))
`2YearFitFullFeatures` <- `2YearFitFullFeatures` %>%
mutate(predicted_in = pmax(predicted_in, 0))
catboost2YearFit <- catboost2YearFit %>%
mutate(predicted_in = pmax(predicted_in, 0))
autogluon_two_year_fit  <- autogluon_two_year_fit_same_year_full_more_cols  %>%
mutate(predicted_in = pmax(predicted_in, 0))
autogluon_two_year_unternehmen  <- autogluon_two_year_fit_same_year_full_unternehmen  %>%
mutate(predicted_in = pmax(predicted_in, 0))
autogluon_two_year_fit_immo_adjusted  <- autogluon_two_year_fit_immo_adjusted  %>%
mutate(predicted_in = pmax(predicted_in, 0))
# fix negative values:
standard <- standard %>%
mutate(predicted_in = pmax(predicted_in, 0))
with_constraints_no_cat <- with_constraints_no_cat %>%
mutate(predicted_in = pmax(predicted_in, 0))
with_constraints <- with_constraints %>%
mutate(predicted_in = pmax(predicted_in, 0))
`2YearFit` <- `2YearFit` %>%
mutate(predicted_in = pmax(predicted_in, 0))
`2YearFitFullFeatures` <- `2YearFitFullFeatures` %>%
mutate(predicted_in = pmax(predicted_in, 0))
catboost2YearFit <- catboost2YearFit %>%
mutate(predicted_in = pmax(predicted_in, 0))
autogluon_two_year_fit  <- autogluon_two_year_fit_same_year_full_more_cols  %>%
mutate(predicted_in = pmax(predicted_in, 0))
autogluon_two_year_unternehmen  <- autogluon_two_year_fit_same_year_full_unternehmen  %>%
mutate(predicted_in = pmax(predicted_in, 0))
autogluon_two_year_fit_immo_adjusted  <- autogluon_two_year_fit_immo_adjusted  %>%
mutate(predicted_in = pmax(predicted_in, 0))
standard_summary <- standard %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(one_year_xboost = mean_relative_error)
autogluon_two_year_fit_immo_adjusted_summary <- autogluon_two_year_fit_immo_adjusted %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(autogluon_two_year_fit_immo_adjusted = mean_relative_error)
two_year_fit_full_features_summary<- `2YearFitFullFeatures` %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(two_year_fit_full_features = mean_relative_error)
with_constraints_summary<- with_constraints %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(with_constraints = mean_relative_error)
with_constraints_no_cat_summary<- with_constraints_no_cat %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(with_constraints_no_cat = mean_relative_error)
two_year_fit_summary <- `2YearFit` %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(two_year_xboost = mean_relative_error)
autogluon2YearFit_summary <- autogluon_two_year_fit %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(autogluon_two_year_fit = mean_relative_error)
autogluon2YearFit_sign_aggreement <- autogluon_two_year_unternehmen %>%
filter(fit_year=="2019_2020") %>%
group_by(fit_year, area_code_target) %>%
summarise(
net_obs  = sum(amount_in - amount_out, na.rm = TRUE),
net_pred = sum(predicted_in - predicted_out, na.rm = TRUE),
.groups = "drop_last"
) %>%
mutate(diff=net_obs-net_pred) %>%
filter(sign(net_obs) == sign(net_pred))
autogluon2YearFit_c_summary <- autogluon_two_year_unternehmen %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(autogluon_two_year_unternehmen = mean_relative_error)
autogluon2YearFit_prev_year_summary <- prev_year %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(autogluon2year_prev_year = mean_relative_error)
catboost2YearFit_fit_summary <- catboost2YearFit %>%
group_by(fit_year, area_code_target) %>%
summarise(amount_in = sum(`amount_in`, na.rm = TRUE), predicted=sum(predicted_in, na.rm=TRUE)) %>%
mutate(relative_error=(abs(predicted-amount_in)/amount_in)) %>%
group_by(fit_year) %>%
summarise(mean_relative_error = mean(`relative_error`, na.rm = TRUE)) %>%
rename(catboost2year = mean_relative_error)
combined_df <- catboost2YearFit_fit_summary  %>%
full_join(with_constraints_no_cat_summary, by="fit_year") %>%
full_join(with_constraints_summary, by="fit_year") %>%
full_join(autogluon2YearFit_prev_year_summary, by = "fit_year") %>%
full_join(two_year_fit_full_features_summary, by = "fit_year") %>%
full_join(autogluon2YearFit_summary, by = "fit_year") %>%
full_join(autogluon2YearFit_c_summary, by="fit_year") %>%
full_join(two_year_fit_summary, by = "fit_year") %>%
full_join(autogluon_two_year_fit_immo_adjusted_summary, by = "fit_year")
df_long_two_year <- combined_df %>%
pivot_longer(-fit_year, names_to = "model", values_to = "mean_relative_error") %>%
group_by(model) %>%
filter(n() >= 2) %>%
ungroup()
ggplot(df_long_two_year, aes(x = fit_year, y = mean_relative_error, color = model)) +
geom_line(size = 1.2, aes(group=model)) +
geom_point(size = 2) +
labs(
title = "Mean relative error of gravity models",
x = "Fit Year",
y = "Mean Relative Error",
color = "Model"
) +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5))
ggplot(autogluon_two_year_fit_same_year_c_importances, aes(x = factor(fit_year), y = Feature, fill = Importance)) +
geom_tile(color = "white") +
scale_fill_viridis_c(option = "plasma") +
labs(x = "Year", y = "Feature", fill = "Importance",
title = "Feature Importances Across Years (Random Forest)") +
theme_minimal(base_size = 14) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
library(readr)
library(dplyr)
library(tidyr)
library(ggplot2)
df <- read_csv("output/all_simulation_results.csv", show_col_types = FALSE) %>%
mutate(
year = as.integer(year),
across(c(delta_gravity, delta_ensemble, delta_amount), ~ suppressWarnings(as.numeric(.))),
area_code = as.factor(area_code),
scenario_name = as.factor(scenario_name)
) %>%
# replace area codes with names
mutate(
area_code = recode(area_code,
`314` = "Lilienfeld",
`502` = "Hallein")
)
